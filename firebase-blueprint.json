{
  "entities": {
    "historyItem": {
      "title": "History Item",
      "description": "Represents a generated document or history entry.",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "Date of generation"
        },
        "type": {
          "type": "string",
          "description": "Type of history item (e.g., 'Relatório', 'Análise')",
          "enum": ["Relatório", "Análise", "Transcrição", "Formalização", "Concatenação", "report", "analyzer", "formalizer", "concatenator", "transcriber"]
        },
        "content": {
          "type": "string",
          "description": "The generated content"
        },
        "title": {
          "type": "string",
          "description": "Title of the item"
        }
      },
      "required": ["date", "type", "content", "title"]
    },
    "trainingFile": {
      "title": "Training File",
      "description": "A custom file provided by the user for model training.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "base64Data": {
          "type": "string",
          "description": "Base64 encoded file data"
        },
        "size": {
          "type": "number",
          "description": "File size in bytes"
        }
      },
      "required": ["name", "type", "base64Data", "size"]
    },
    "tokenUsage": {
      "title": "Token Usage",
      "description": "Record of API tokens used by the user",
      "type": "object",
      "properties": {
        "tokens": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      },
      "required": ["tokens", "date", "model"]
    },
    "userProfile": {
      "title": "User Profile",
      "description": "Basic user data like email for admin view",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "trialEndsAt": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "paidUntil": {
          "type": "string"
        }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/userProfile"
      },
      "description": "User profile"
    },
    "/users/{userId}/tokenUsage/{usageId}": {
      "schema": {
        "$ref": "#/entities/tokenUsage"
      },
      "description": "User's token usage records"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": {
        "$ref": "#/entities/historyItem"
      },
      "description": "User's generated document history"
    },
    "/users/{userId}/trainingFiles/{fileId}": {
      "schema": {
        "$ref": "#/entities/trainingFile"
      },
      "description": "User's model training files"
    }
  }
}
