rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /cpfRecords/{cpf} {
      allow get: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'ricardoasdeandrade@gmail.com' || request.auth.uid == 'OxqvUl9FcFSTaWdFzyWHYFxrD1G2');
      allow list: if request.auth != null && (request.auth.token.email == 'ricardoasdeandrade@gmail.com' || request.auth.uid == 'OxqvUl9FcFSTaWdFzyWHYFxrD1G2');
      allow create, update: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'ricardoasdeandrade@gmail.com' || request.auth.uid == 'OxqvUl9FcFSTaWdFzyWHYFxrD1G2');
      allow delete: if request.auth != null && (request.auth.token.email == 'ricardoasdeandrade@gmail.com' || request.auth.uid == 'OxqvUl9FcFSTaWdFzyWHYFxrD1G2');
      
      match /tokenUsage/{usageId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'ricardoasdeandrade@gmail.com' || request.auth.uid == 'OxqvUl9FcFSTaWdFzyWHYFxrD1G2');
      }
      
      match /history/{historyId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'ricardoasdeandrade@gmail.com' || request.auth.uid == 'OxqvUl9FcFSTaWdFzyWHYFxrD1G2');
      }

      match /trainingFiles/{fileId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'ricardoasdeandrade@gmail.com' || request.auth.uid == 'OxqvUl9FcFSTaWdFzyWHYFxrD1G2');
      }
    }
  }
}
